<script>
/* ── GRAIN: generate noise texture once ──────────────────── */
(function () {
  const c = document.createElement('canvas');
  c.width = c.height = 256;
  const ctx = c.getContext('2d');
  const img = ctx.createImageData(256, 256);
  for (let i = 0; i < img.data.length; i += 4) {
    const v = Math.random() * 255 | 0;
    img.data[i] = img.data[i + 1] = img.data[i + 2] = v;
    img.data[i + 3] = 255;
  }
  ctx.putImageData(img, 0, 0);
  document.getElementById('grain').style.backgroundImage = `url(${c.toDataURL()})`;
})();


/* ── SCRAMBLE ────────────────────────────────────────────── */
const GLITCH_CHARS = '!@#$%^&*()[]{}<>?/|\\+=~,.;:0123456789ABCDEFGHIJKLMNOPQRSTUVWXYZ';

function randChar(c) {
  // Preserve spaces and apostrophes — everything else gets scrambled
  if (c === ' ' || c === '\'' || c === '.') return c;
  return GLITCH_CHARS[Math.floor(Math.random() * GLITCH_CHARS.length)];
}

function scrambleBox(boxEl) {
  const spans = Array.from(boxEl.querySelectorAll('[data-txt]'));
  const finals = spans.map(s => s.getAttribute('data-txt'));

  let tick = 0;
  const TICKS = 4; // 3–5 frames at ~16ms each = ~64ms total

  function step() {
    tick++;
    if (tick >= TICKS) {
      spans.forEach((s, i) => { s.textContent = finals[i]; });
      return;
    }
    spans.forEach((s, i) => {
      s.textContent = finals[i].split('').map(randChar).join('');
    });
    setTimeout(step, 16);
  }

  // First frame: full scramble immediately
  spans.forEach((s, i) => {
    s.textContent = finals[i].split('').map(randChar).join('');
  });
  setTimeout(step, 16);
}


/* ── IMPACT: jolt all visible boxes + shake frame ────────── */
function triggerImpact() {
  const frame = document.getElementById('frame');

  // Jolt all currently visible staircase boxes
  TIMELINE.forEach(({ id }) => {
    const el = document.getElementById(id);
    if (el && el.classList.contains('visible')) {
      el.classList.remove('jolting');
      void el.offsetWidth;
      el.classList.add('jolting');
      el.addEventListener('animationend', () => el.classList.remove('jolting'), { once: true });
    }
  });

  // Micro-shake the whole frame
  frame.classList.remove('shaking');
  void frame.offsetWidth;
  frame.classList.add('shaking');
  frame.addEventListener('animationend', () => frame.classList.remove('shaking'), { once: true });
}


/* ── TIMELINE ────────────────────────────────────────────── */
const TIMELINE = [
  { id: 'b1', showAt:     0, anim: 'a-slam'    },
  { id: 'b2', showAt:  2000, anim: 'a-left'    },
  { id: 'b3', showAt:  4000, anim: 'a-left'    },
  { id: 'b4', showAt:  6000, anim: 'a-explode' },
  { id: 'b5', showAt:  8000, anim: 'a-glitch'  },
  { id: 'b6', showAt: 10000, anim: 'a-right'   },
  { id: 'b7', showAt: 12000, anim: 'a-pop'     },
  { id: 'b8', showAt: 13000, anim: 'a-burst'   },
];

const ALL_ANIMS = ['a-slam','a-left','a-right','a-explode','a-glitch','a-pop','a-burst','a-fade'];


/* ── STATE ───────────────────────────────────────────────── */
let running   = false;
let handles   = [];
let rafId     = null;
let recRafId  = null;
let t0        = null;


/* ── SHOW A BOX ──────────────────────────────────────────── */
function showBox(entry) {
  const el = document.getElementById(entry.id);

  // Clear any residual animation classes, force reflow, apply new one
  ALL_ANIMS.forEach(a => el.classList.remove(a));
  void el.offsetWidth;
  el.classList.add(entry.anim);
  el.classList.add('visible');
  el.addEventListener('animationend', () => {
    ALL_ANIMS.forEach(a => el.classList.remove(a));
  }, { once: true });

  // Character scramble
  scrambleBox(el);

  // Impact effect on all other boxes (skip b1 — it's the header, not a stack box)
  if (entry.id !== 'b1') triggerImpact();
}


/* ── RESET ───────────────────────────────────────────────── */
function reset() {
  handles.forEach(clearTimeout);
  handles = [];
  if (rafId)    { cancelAnimationFrame(rafId);    rafId    = null; }
  if (recRafId) { cancelAnimationFrame(recRafId); recRafId = null; }

  TIMELINE.forEach(({ id }) => {
    const el = document.getElementById(id);
    el.classList.remove('visible', 'jolting', ...ALL_ANIMS);
    // Restore original text
    el.querySelectorAll('[data-txt]').forEach(s => {
      s.textContent = s.getAttribute('data-txt');
    });
  });

  const s9 = document.getElementById('s9');
  s9.classList.remove('visible', 'a-fade');

  document.getElementById('blackout').classList.remove('cut');
  document.getElementById('frame').classList.remove('shaking');
  document.getElementById('rec').classList.remove('on');
  document.getElementById('rec-time').textContent = '00:00:00';
  document.getElementById('timer').textContent = '0.0s';
  document.getElementById('bg').style.animationPlayState = 'paused';
  document.getElementById('scanlines').style.animationPlayState = 'paused';
}


/* ── PLAY ────────────────────────────────────────────────── */
function play() {
  if (running) {
    reset();
    running = false;
    setBtn('play');
    return;
  }

  reset();
  running = true;
  setBtn('stop');
  t0 = performance.now();

  // Kick continuous-loop elements
  document.getElementById('bg').style.animationPlayState       = 'running';
  document.getElementById('scanlines').style.animationPlayState = 'running';
  document.getElementById('rec').classList.add('on');

  // Elapsed timer display
  (function tickTimer() {
    if (!running) return;
    const s = Math.min((performance.now() - t0) / 1000, 15);
    document.getElementById('timer').textContent = s.toFixed(1) + 's';
    if (s < 15.05) rafId = requestAnimationFrame(tickTimer);
  })();

  // REC clock (ticks every rAF frame — smooth)
  (function tickRec() {
    if (!running) return;
    const s = (performance.now() - t0) / 1000;
    const mm = Math.floor(s / 60);
    const ss = Math.floor(s % 60);
    document.getElementById('rec-time').textContent =
      '00:' +
      String(mm).padStart(2, '0') + ':' +
      String(ss).padStart(2, '0');
    recRafId = requestAnimationFrame(tickRec);
  })();

  // Staircase entries
  TIMELINE.forEach(entry => {
    handles.push(setTimeout(() => showBox(entry), entry.showAt));
  });

  // 0:14 — clear all staircase boxes, reveal final frame
  handles.push(setTimeout(() => {
    TIMELINE.forEach(({ id }) => {
      document.getElementById(id).classList.remove('visible');
    });
    const s9 = document.getElementById('s9');
    ALL_ANIMS.forEach(a => s9.classList.remove(a));
    void s9.offsetWidth;
    s9.classList.add('visible', 'a-fade');
  }, 14000));

  // 0:15 — cut to black
  handles.push(setTimeout(() => {
    document.getElementById('s9').classList.remove('visible');
    document.getElementById('blackout').classList.add('cut');
  }, 15000));

  // Done
  handles.push(setTimeout(() => {
    running = false;
    setBtn('replay');
  }, 15300));
}


/* ── BUTTON STATE ────────────────────────────────────────── */
function setBtn(state) {
  const b = document.getElementById('playBtn');
  if (state === 'play')   { b.textContent = '▶ PLAY';   b.classList.remove('stop'); }
  if (state === 'stop')   { b.textContent = '■ STOP';   b.classList.add('stop');    }
  if (state === 'replay') { b.textContent = '↺ REPLAY'; b.classList.remove('stop'); }
}
</script>

