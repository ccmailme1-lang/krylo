  uniform vec3 uActiveNodes[10];   // x, y coordinates, z = active flag         
  uniform vec4 uActiveVectors[10]; // D, V, A, T vectors                        
  varying float vDisplacement;                                                  
                                                                                
  void main() {                                                                 
    vec3 pos = position;                                                        
    float totalDisplacement = 0.0;                                              
                                                                                
    for (int i = 0; i < 10; i++) {                                              
      if (uActiveNodes[i].z > 0.5) { // Node is flagged as active               
        float dist = distance(pos.xy, uActiveNodes[i].xy);                      
        float amplitude = uActiveVectors[i].z; // Exposure (A) maps to          
  Amplitude                                                                     
        float frequency = 2.0 + uActiveVectors[i].y * 4.0; // Volatility (V)    
  maps to Frequency                                                             
                                                                                
        // Localized ripple deformation                                         
        totalDisplacement += (amplitude / (dist * dist + 0.15)) * sin(uTime *   
  3.0 - dist * frequency);                                                      
      }                                                                         
    }                                                                           
                                                                                
    pos.z += totalDisplacement;                                                 
    gl_Position = projectionMatrix * modelViewMatrix * vec4(pos, 1.0);          
  }                                                                             
                                                                                
