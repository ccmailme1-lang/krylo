  126 function mockStage02(signalPacket, pliResult) {
  127   const { gap, velocity, window: win, coverage } = pliResult.components;
  128   const baseScore = 50 + Math.round(pliResult.pli * 50);
  129
  130   // Project score trajectory over 72h assuming velocity decay of 8% per period
  131   const decayRate  = signalPacket.velocity_trend === 'rising' ? 1.05 : 0.92;
  132   const spreadBase = Math.max(3, Math.round((1 - pliResult.ar / 10) * 15));
  133
  134   const trajectory = ['+6h', '+12h', '+24h', '+48h', '+72h'].map((t, i) => {
  135     const multiplier = Math.pow(decayRate, i + 1);
  136     const score = Math.min(100, Math.max(0, Math.round(baseScore * multiplier)));
  137     const spread = spreadBase * (i + 1);
  138     return {
  139       t,
  140       score,
  141       upper: Math.min(100, score + spread),
  142       lower: Math.max(0, score - spread),
  143     };
  144   });
