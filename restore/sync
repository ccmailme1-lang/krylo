constructor(maxTasksPerFrame = 10) {
this.queue = [];
this.frame = 0;
this.maxTasksPerFrame = maxTasksPerFrame;
}

schedule(task, priority = 0) {
this.queue.push({ task, priority });
}

tick() {
this.frame++;

const frameStart = Date.now();

const prioritized = arbiter.prioritize(this.queue);
const batch = prioritized.slice(0, this.maxTasksPerFrame);
const deferred = prioritized.slice(this.maxTasksPerFrame);

this.queue = deferred;

for (const entry of batch) {
new TaskRuntime().execute(entry.task, { frame: this.frame });
}

const frameEnd = Date.now();

telemetry.frameProcessed();

telemetry.calculateLoad(
prioritized.length,
frameEnd - frameStart,
deferred.length
);

return {
processed: batch.length,
deferred: deferred.length
};
}
}

