class SchedulerEngine {
  constructor(maxTasksPerFrame = 10) {
    this.queue = [];
    this.frame = 0;
    this.maxTasksPerFrame = maxTasksPerFrame;
  }

  schedule(task, priority = 0) {
    this.queue.push({
      task,
      priority
    });
  }

  tick() {
    this.frame++;

    const frameStart = performance.now();

    const prioritized = arbiter.prioritize(this.queue);

    const currentBatch = prioritized.slice(0, this.maxTasksPerFrame);

    const deferredBatch = prioritized.slice(this.maxTasksPerFrame);

    this.queue = deferredBatch;

    for (const entry of currentBatch) {
      runtime.execute(entry.task, {
        frame: this.frame
      });
    }

    const frameEnd = performance.now();

    telemetry.frameProcessed();

    telemetry.calculateLoad(
      prioritized.length,
      frameEnd - frameStart,
      deferredBatch.length
    );

    return {
      processed: currentBatch.length,
      deferred: deferredBatch.length
    };
  }
}

