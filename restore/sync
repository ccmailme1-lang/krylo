class ExecutionOrchestrator {
  constructor(ledger, frameRef) {
    this.scheduler = new SchedulerEngine();
    this.runtime = new TaskRuntime();
    this.ledger = ledger;
    this.frameRef = frameRef;
  }

  submit(task, type, priority = 0) {
    this.scheduler.schedule(() => {
      const frame = this.frameRef.current();

      const result =
        this.runtime.execute(task, { frame });

      const event =
        new Event(frame, type, result);

      this.ledger.append(event);

      telemetry.eventRecorded();
    }, priority);
  }

  tick() {
    this.frameRef.next();
    this.scheduler.tick();
  }
}

