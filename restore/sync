class FrameArbiter {
  prioritize(queue) {
    return [...queue].sort((a, b) => b.priority - a.priority);
  }
}

const arbiter = new FrameArbiter();

// --------------------------------------------------
// LEDGER
// --------------------------------------------------

class IntegrityLedger {
  constructor() {
    this.chain = [];
  }

  record(frame, type, payload, priority) {
    const timestamp = Date.now();

    const prevHash =
      this.chain.length > 0
        ? this.chain[this.chain.length - 1].hash
        : '';

    const hash = crypto
      .createHash('sha256')
      .update(
        JSON.stringify({
          frame,
          type,
          payload,
          timestamp,
          priority,
          prevHash
        })
      )
      .digest('hex');

    const entry = {
      frame,
      type,
      payload,
      timestamp,
      priority,
      prevHash,
      hash
    };

    this.chain.push(entry);

    telemetry.eventRecorded();

    return entry;
  }

  getChain() {
    return this.chain;
  }
}

const ledger = new IntegrityLedger();

// --------------------------------------------------
// RUNTIME
// --------------------------------------------------

class TaskRuntime {
  execute(task, context) {
    telemetry.taskExecuted();
    task(context);
  }
}

