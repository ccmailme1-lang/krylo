function hash(obj) {
  return crypto
    .createHash("sha256")
    .update(JSON.stringify(obj))
    .digest("hex");
}

// ===============================
// EVENT CREATION (LEDGER CHAIN)
// ===============================
function createEvent(prev, frame, type, payload, priority = 0) {
  const base = {
    frame,
    type,
    payload,
    timestamp: Date.now(),
    priority
  };

  const event = {
    ...base,
    prevHash: prev?.hash || ""
  };

  event.hash = hash(event);

  telemetry.eventRecorded();

  return event;
}

// ===============================
// FRAME ARBITER (WO-1064)
// ===============================
class FrameArbiter {
  prioritize(queue) {
    return queue.slice().sort((a, b) => {
      if ((b.priority ?? 0) !== (a.priority ?? 0)) {
        return (b.priority ?? 0) - (a.priority ?? 0);
      }

      return (a.timestamp ?? 0) - (b.timestamp ?? 0);
    });
  }
}

const arbiter = new FrameArbiter();

// ===============================
// FRAME BUDGET (WO-1065)
// ===============================
class FrameBudget {
  constructor(limitMs = 16.67) {
    this.limitMs = limitMs;
    this.start = 0;
  }

  begin() {
    this.start = performance.now();
  }

  exceeded() {
    return performance.now() - this.start >= this.limitMs;
  }
}

// ===============================
// SCHEDULER ENGINE
// ===============================
class SchedulerEngine {
  constructor() {
    this.queue = [];
  }

  schedule(task, priority = 0) {
    this.queue.push({
      task,
      priority,
      timestamp: Date.now()
    });
  }

  tick() {
    const batch = arbiter.prioritize(this.queue);
    this.queue = [];

    const budget = new FrameBudget(16.67);
    budget.begin();

    const deferred = [];

    for (let i = 0; i < batch.length; i++) {
      const entry = batch[i];

      if (budget.exceeded()) {
        for (; i < batch.length; i++) {
          deferred.push(batch[i]);
        }
        break;
      }

      entry.task();
    }

    this.queue = deferred;

    telemetry.frameProcessed();
  }
}

// ===============================
// RUNTIME
// ===============================
class TaskRuntime {
  execute(task) {
    telemetry.taskExecuted();
    return task();
  }
}

