const { FrameArbiter } = require('../arbitration/frame-arbiter.cjs');

const crypto = require('crypto');

const telemetry = {
framesProcessed: 0,
tasksExecuted: 0,
eventsRecorded: 0,
replayRequests: 0,
runtimeStartedAt: Date.now(),

load: {
qpi: 0,
fsr: 0,
ssi: 0,
deferred: 0
},

frameProcessed() {
this.framesProcessed++;
},

taskExecuted() {
this.tasksExecuted++;
},

eventRecorded() {
this.eventsRecorded++;
},

replayRequested() {
this.replayRequests++;
},

calculateLoad(queueDepth, frameDurationMs, deferredCount) {
this.load.qpi = queueDepth;
this.load.fsr = frameDurationMs / 16.67;
this.load.ssi =
(this.load.qpi * 0.02) +
(this.load.fsr * 0.5) +
(deferredCount * 0.1);
this.load.deferred = deferredCount;
}
};

const arbiter = new FrameArbiter();

class IntegrityLedger {
constructor() {
this.chain = [];
}

record(frame, type, payload, priority) {
const timestamp = Date.now();

const prevHash =
this.chain.length > 0
? this.chain[this.chain.length - 1].hash
: '';

const hash = crypto
.createHash('sha256')
.update(
JSON.stringify({
frame,
type,
payload,
timestamp,
priority,
prevHash
})
)
.digest('hex');

const entry = {
frame,
type,
payload,
timestamp,
priority,
prevHash,
hash
};

this.chain.push(entry);
telemetry.eventRecorded();

return entry;
}

getChain() {
return this.chain;
}
}

